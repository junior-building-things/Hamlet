# Image for the `hamlet-digests` Cloud Run Job — the batch digest pipeline
# that used to run on a Mac LaunchAgent.
#
# It is deliberately NOT the standalone Next.js image: the entrypoint runs
# tools/run-digests.ts, which imports lib/ directly, so it needs the
# TypeScript sources plus node_modules (including tsx). Size does not matter
# here the way it does for the request-serving service — nothing waits on
# this container's cold start.
#
# Everything it needs beyond that is identical to the service: the `claude`
# CLI for LLM calls, authenticated by CLAUDE_CODE_OAUTH_TOKEN.
FROM node:22-slim

WORKDIR /app

RUN apt-get update \
    && apt-get install -y --no-install-recommends ripgrep ca-certificates \
    && rm -rf /var/lib/apt/lists/* \
    && npm install -g @anthropic-ai/claude-code \
    && claude --version

# devDependencies are required: tsx runs the entrypoint.
COPY package.json package-lock.json ./
RUN npm ci

COPY lib ./lib
COPY tools ./tools
COPY tsconfig.json ./

# The CLI writes config/session state under $HOME on every invocation.
ENV HOME=/home/hamlet
RUN mkdir -p /home/hamlet && chmod 777 /home/hamlet

# Mode is argv[2]: all | refresh | digests | watch-trigger. Override per
# execution with `gcloud run jobs execute --args <mode>`.
ENTRYPOINT ["npx", "tsx", "tools/run-digests.ts"]
CMD ["all"]
